# Database — connection_limit and pool_timeout are critical for high concurrency
# Use PgBouncer in production and set connection_limit to match PgBouncer pool size
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/g_ai?connection_limit=25&pool_timeout=10"

# Auth
JWT_SECRET="change-this-to-a-long-random-secret"

# Redis
REDIS_URL="redis://localhost:6379"

# CORS (comma-separated origins)
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# AWS S3 (optional — leave blank to use local /uploads/)
S3_BUCKET_NAME=""
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""

# Client-side API URL (Vite)
VITE_API_URL="http://localhost:3000"
